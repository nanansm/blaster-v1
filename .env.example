# ============================================
# Mote Blaster - Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values
# ============================================

# --------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------
DATABASE_URL=postgres://postgres:password@localhost:5432/mote

# --------------------------------------------
# Redis (for BullMQ worker - future use)
# --------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Mock Mode - set to true to skip all API calls and use mock data
# --------------------------------------------
NEXT_PUBLIC_MOCK_MODE=true

# --------------------------------------------
# Better Auth (Authentication)
# --------------------------------------------
# URL of your deployment (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# Secret key for session encryption (generate a strong random string for production)
BETTER_AUTH_SECRET=your_super_secret_key_change_in_production

# Alternative auth secret (also supported)
# AUTH_SECRET=your_super_secret_key_change_in_production

# --------------------------------------------
# Google OAuth (Sign-in with Google)
# --------------------------------------------
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --------------------------------------------
# WPPConnect (WhatsApp API)
# --------------------------------------------
# Base URL of your WPPConnect server
WPPCONNECT_BASE_URL=http://localhost:21465

# Secret key for WPPConnect authentication
WPPCONNECT_SECRET_KEY=your_wppconnect_secret

# --------------------------------------------
# Xendit (Payment Gateway for Subscriptions)
# --------------------------------------------
# Create at: https://dashboard.xendit.co/settings/developers#api-keys
XENDIT_SECRET_KEY=your_xendit_secret_key

# Xendit webhook verification token (optional)
# XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_token

# --------------------------------------------
# Google Sheets API (for contact import)
# --------------------------------------------
# Service account key JSON (base64 encoded) or path to key file
# GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account.json
# GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# --------------------------------------------
# Admin Access
# --------------------------------------------
# Comma-separated list of admin email addresses
ADMIN_EMAILS=nanan@motekreatif.com,admin@mote.com

# --------------------------------------------
# Deployment (Easypanel)
# --------------------------------------------
# NODE_ENV=production
# NEXT_TELEMETRY_DISABLED=1
