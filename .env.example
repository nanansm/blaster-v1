# Database (optional for local testing with MOCK_MODE)
DATABASE_URL=postgres://postgres:password@localhost:5432/mote

# Redis (optional for local testing with MOCK_MODE)
REDIS_URL=redis://localhost:6379

# Mock Mode - set to true to skip all API calls and use mock data
NEXT_PUBLIC_MOCK_MODE=true

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_secret_key_here

# Google OAuth (not needed in mock mode)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# WPPConnect (not needed in mock mode)
WPPCONNECT_BASE_URL=http://localhost:21465
WPPCONNECT_SECRET_KEY=your_wppconnect_secret

# Xendit (not needed in mock mode)
XENDIT_SECRET_KEY=your_xendit_secret_key

# Admin Emails (comma-separated)
ADMIN_EMAILS=nanan@motekreatif.com,admin@mote.com
