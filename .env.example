# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mote_blaster

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-change-in-production
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin Credentials (for email/password login)
ADMIN_EMAIL=admin@moteblaster.com
ADMIN_PASSWORD=admin123secure

# Xendit (Payment Gateway)
XENDIT_SECRET_KEY=xnd_development_your_key
XENDIT_WEBHOOK_TOKEN=your-webhook-token

# WhatsApp Settings
WA_SESSION_DIR=./wa_sessions
